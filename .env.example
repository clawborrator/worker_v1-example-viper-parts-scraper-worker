# Copy to `.env`, fill in, then `docker compose up -d`.
# Anything starting with `#` is a comment.

# === Anthropic auth (pick ONE; first-match-wins: A then B then C) ====
ANTHROPIC_API_KEY=

# Path B (PREFERRED): `claude setup-token` output.
CLAUDE_CODE_OAUTH_TOKEN=

# Path C: legacy OAuth access token (fallback only).
ANTHROPIC_ACCESS_TOKEN=

# Model: opus | sonnet | haiku. Use sonnet. The agent's main
# judgment is classifying scraped posts as buy/sell/general and
# extracting a clean structured summary. Reasoning quality
# matters; the cycle runs every 6h so token spend stays modest.
MODEL=sonnet

# === REQUIRED: clawborrator hub integration ======================

# Channel token (ck_live_...). Mint via:
#   claw token mint --name viper-parts-scraper
CLAWBORRATOR_TOKEN=

CLAWBORRATOR_HUB_URL=wss://next.clawborrator.com

# Optional: routing-name override. Without this, every worker_v1
# container has cwd=/workspace so the hub gives the first one
# @workspace and UUID-suffixes the rest. Set to a meaningful slug
# and your scraper registers as `@viper-parts-scraper` instead.
CLAWBORRATOR_ROUTING_NAME=viper-parts-scraper

# === REQUIRED: the agent code (the sibling repo) =================

REPO_URL=https://github.com/clawborrator/worker_v1-example-viper-parts-scraper-repo
REPO_REF=main
REPO_DIR_NAME=repo

# PAT for git push. The scraper commits data/listings/<ts>.json
# every cycle as the structured output + audit. Requires `repo`
# scope.
REPO_PAT=
REPO_PAT_USER=x-access-token

GIT_USER_EMAIL=
GIT_USER_NAME=

# === REQUIRED: notification target ===============================

# The peer the scraper calls route_to_peer against after each
# cycle to deliver a past-tense digest of new matches. Format
# is the routing name visible in `claw peers ls` (no `@` prefix
# needed, the agent adds it).
NOTIFY_PEER=clauderemote

# === Boot prompt ================================================

CLAUDE_INITIAL_PROMPT=Read /workspace/repo/CLAUDE.md carefully. That is your playbook. Then bootstrap the cron and execute one warmup cycle.

# === Behavior knobs =============================================

CLAUDE_SKIP_PERMISSIONS=1
DISABLE_AUTOENTER=0
